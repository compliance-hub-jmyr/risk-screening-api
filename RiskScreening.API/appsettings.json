{
  "AllowedHosts": "*",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Issuer": "RiskScreening",
    "Audience": "RiskScreening",
    "ExpirationHours": 24
  },
  "OpenApi": {
    "Title": "RiskScreening API",
    "Version": "v1",
    "Description": "Risk Screening Platform API",
    "Contact": {
      "Name": "RiskScreening Team",
      "Email": "dev@riskscreening.com"
    }
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Forwarded-For",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "POST:/api/authentication/sign-in",
        "Period": "1m",
        "Limit": 5
      },
      {
        "Endpoint": "GET:/api/lists/*",
        "Period": "1m",
        "Limit": 20
      },
      {
        "Endpoint": "*:/api/*",
        "Period": "1m",
        "Limit": 100
      }
    ]
  }
}
